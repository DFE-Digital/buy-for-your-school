<%= content_for :pre_main do %>
  <div class="dfe-grid-row">
    <div class="dfe-grid-column-two-thirds">
      <h1 class="dfe-heading-xl homepage-heading">
        <%= t('header_title') %>
      </h1>
      <p class="dfe-body-l">
        <%= t('header_description') %>
      </p>
    </div>
  </div>
<% end %>

<div class="govuk-!-margin-top-4">
  <% if @energy_banner %>
    <%= render partial: 'energy_banner', locals: { banner: @energy_banner } %>
  <% end %>

  <% if @featured_offers.present? %>
    <h2 class="govuk-heading-m"><%= t(".offers_title") %></h2>
    <div class="dfe-grid-container offers-grid-container">
      <%= render @featured_offers %>
    </div>
  <% end %>

  <h2 class="govuk-heading-m"><%= t(".title") %></h2>
  <p class="govuk-body"><%= t(".subtitle") %></p>
  <div class="homepage-category-list">
    <ul class="chevron-card-list">
      <%= render @categories %>
    </ul>
  </div>
</div>

<% content_for :sidebar do %>
  <h2 class="govuk-heading-m"><%= t(".support_heading") %></h2>
  <p class="govuk-body">
    <%= govuk_link_to t(".procurement_support"), framework_requests_path, target: "_blank", rel: "noopener noreferrer", data: { track_internal_link: true } %>
  </p>
<% end %>
