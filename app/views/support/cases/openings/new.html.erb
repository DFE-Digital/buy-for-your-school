<%= content_for :title, I18n.t("support.case_openings.new.header") %>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l"><%= I18n.t("support.case_openings.new.header") %></h1>

    <table class="govuk-table">
      <tbody class="govuk-table__body">
        <tr class="govuk-table__row">
          <th class="govuk-table__header" scope="row" ><%= I18n.t("support.case_openings.new.table.case_id") %></th>
          <td class="govuk-table__cell"><%= @current_case.ref %></td>
        </tr>
        <tr class="govuk-table__row">
          <th class="govuk-table__header" scope="row" ><%= I18n.t("support.case_openings.new.table.status") %></th>
          <td class="govuk-table__cell"><%= @current_case.state %></td>
        </tr>
      </tbody>
    </table>

    <br>

    <div class="govuk-button-group">
      <%= link_to I18n.t("support.case_openings.new.reopen"), support_case_opening_path(@current_case), method: :post, class: "govuk-button govuk-button--warning", role: "button" %>
      <%= link_to I18n.t("support.case_openings.new.cancel"), @back_url, class: "govuk-link" %>
    </div>
  </div>
</div>
