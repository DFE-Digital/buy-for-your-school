<%= tag.form(
  id: "search",
  action: "/search",
  method: "get",
  role: "search",
) do %>
  <%= render "govuk_publishing_components/components/search", {
    name: "query",
    value: params[:query],
    label_text: "",
    label_size: "s",
    on_govuk_blue: true,
    homepage: true,
    size: "large",
  } %>
<% end %>
